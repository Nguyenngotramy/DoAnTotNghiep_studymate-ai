# Hugging Face Space variables/secrets for the Spring Boot API.
PORT=8080
JAVA_OPTS=-XX:MaxRAMPercentage=75 -XX:+UseG1GC
TOMCAT_MAX_THREADS=80
TOMCAT_MIN_SPARE_THREADS=10
TOMCAT_ACCEPT_COUNT=100
TOMCAT_CONNECTION_TIMEOUT=20s
APP_LOG_LEVEL=INFO

# Public application URLs. Use the Cloudflare Pages production URL.
FRONTEND_URL=https://your-project.pages.dev
APP_PUBLIC_BASE_URL=https://your-project.pages.dev/api

# MongoDB Atlas.
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/studymate?retryWrites=true&w=majority

# Same values must also be configured in the AI Agent and Cloudflare Pages.
AI_AGENT_URL=https://your-ai-agent-space.hf.space
AI_AGENT_SERVICE_KEY=replace-with-a-long-random-service-key
AI_AGENT_TIMEOUT_SECONDS=45
JWT_SECRET=replace-with-at-least-32-random-characters

GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-google-app-password

CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1-mini
OPENAI_VISION_MODEL=openai/gpt-4o-mini

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
