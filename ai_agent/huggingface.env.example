# Hugging Face Space variables/secrets for the FastAPI AI Agent.
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_AGENT_MODEL=meta-llama/llama-3.2-3b-instruct:free
AI_AGENT_SERVICE_KEY=replace-with-the-same-key-used-by-spring-and-cloudflare

# Attach persistent storage to the Space. Hugging Face mounts it at /data.
STUDYMIND_DB_PATH=/data/studymind_db
CHAT_DB_PATH=/data/chat_history.sqlite3
KB_COLLECTION_NAME=knowledge_v2

BACKEND_API_URL=https://studymate-ai-9lj.pages.dev/api
ALLOWED_ORIGINS=https://studymate-ai-9lj.pages.dev
ALLOWED_FILE_HOSTS=studymate-ai-9lj.pages.dev,res.cloudinary.com

# Suitable starting point for about 100 registered users with low concurrency.
UVICORN_WORKERS=1
LLM_CONCURRENCY_LIMIT=6
LLM_HEADROOM_PERCENT=25
LLM_QUEUE_TIMEOUT=8
LLM_PRIORITY_QUEUE_TIMEOUT=15
AI_INTRO_PRIORITY_REQUESTS=3
LLM_REQUEST_TIMEOUT=60
LLM_TURN_TIMEOUT=110
AI_HTTP_TIMEOUT=120
LLM_MAX_RETRIES=1
PROVIDER_FAILURE_COOLDOWN_SECONDS=15
STRUCTURED_OUTPUT_RETRIES=1

MAX_SESSION_MESSAGES=40
CHAT_HISTORY_FOR_LLM=8
MAX_PROMPT_CHARS=14000
MAX_MESSAGE_CHARS=3500
DEFAULT_KB_RESULTS=3
MIN_KB_RELEVANCE=0.25
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
KB_CHUNK_SIZE=900
KB_CHUNK_OVERLAP=120
MAX_KB_CONTEXT_CHARS=4500
MAX_KB_SOURCE_CHARS=1200
MAX_REMOTE_FILE_BYTES=15728640
MAX_UPLOAD_FILE_BYTES=15728640
LLM_MAX_OUTPUT_TOKENS=1200
LLM_MAX_PROVIDER_OUTPUT_TOKENS=2048
CLASSIFIER_MAX_TOKENS=200
QUIZ_MAX_TOKENS=1800
FLASHCARD_MAX_TOKENS=1500
SUMMARY_MAX_TOKENS=1000
TUTOR_MAX_TOKENS=1000
AI_CHAT_MODEL=meta-llama/llama-3.2-3b-instruct:free
AI_SUMMARY_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
AI_STRUCTURED_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
AI_REASONING_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
AI_PAID_FALLBACK_MODEL=anthropic/claude-haiku-4.5
