OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_AGENT_MODEL=anthropic/claude-haiku-4-5
AI_AGENT_SERVICE_KEY=replace-with-the-same-key-used-by-backend
AI_AGENT_HOST=0.0.0.0
AI_AGENT_PORT=8001
AI_AGENT_RELOAD=true
KB_COLLECTION_NAME=knowledge_v2
ALLOWED_FILE_HOSTS=backend,localhost,127.0.0.1,res.cloudinary.com
AI_AGENT_WORKERS=1
LLM_CONCURRENCY_LIMIT=12
LLM_HEADROOM_PERCENT=25
LLM_QUEUE_TIMEOUT=8
LLM_PRIORITY_QUEUE_TIMEOUT=15
AI_INTRO_PRIORITY_REQUESTS=3
LLM_REQUEST_TIMEOUT=20
LLM_TURN_TIMEOUT=35
LLM_MAX_RETRIES=0
PROVIDER_FAILURE_COOLDOWN_SECONDS=60
AI_HTTP_TIMEOUT=40
STRUCTURED_OUTPUT_RETRIES=0
MAX_SESSION_MESSAGES=40
CHAT_HISTORY_FOR_LLM=8
MAX_PROMPT_CHARS=14000
MAX_MESSAGE_CHARS=3500
DEFAULT_KB_RESULTS=3
MIN_KB_RELEVANCE=0.25
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
KB_CHUNK_SIZE=900
KB_CHUNK_OVERLAP=120
MAX_KB_CONTEXT_CHARS=4500
MAX_KB_SOURCE_CHARS=1200
MAX_REMOTE_FILE_BYTES=15728640
MAX_UPLOAD_FILE_BYTES=15728640
LLM_MAX_OUTPUT_TOKENS=900
