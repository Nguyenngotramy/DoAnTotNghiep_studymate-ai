FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV STUDYMIND_DB_PATH=/data/studymind_db
ENV KB_COLLECTION_NAME=knowledge_v2
ENV CHAT_DB_PATH=/data/chat_history.sqlite3
ENV MAX_SESSION_MESSAGES=40
ENV CHAT_HISTORY_FOR_LLM=8
ENV MAX_PROMPT_CHARS=14000
ENV MAX_MESSAGE_CHARS=3500
ENV DEFAULT_KB_RESULTS=3
ENV MIN_KB_RELEVANCE=0.25
ENV EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
ENV KB_CHUNK_SIZE=900
ENV KB_CHUNK_OVERLAP=120
ENV MAX_KB_CONTEXT_CHARS=4500
ENV MAX_KB_SOURCE_CHARS=1200
ENV MAX_REMOTE_FILE_BYTES=15728640
ENV MAX_UPLOAD_FILE_BYTES=15728640
ENV LLM_MAX_OUTPUT_TOKENS=900
ENV LLM_CONCURRENCY_LIMIT=12
ENV LLM_HEADROOM_PERCENT=25
ENV LLM_QUEUE_TIMEOUT=8
ENV LLM_PRIORITY_QUEUE_TIMEOUT=15
ENV AI_INTRO_PRIORITY_REQUESTS=3
ENV LLM_REQUEST_TIMEOUT=20
ENV LLM_TURN_TIMEOUT=35
ENV LLM_MAX_RETRIES=0
ENV PROVIDER_FAILURE_COOLDOWN_SECONDS=60
ENV AI_HTTP_TIMEOUT=40
ENV STRUCTURED_OUTPUT_RETRIES=0
ENV UVICORN_WORKERS=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN mkdir -p /data/studymind_db

EXPOSE 8001
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port 8001 --workers ${UVICORN_WORKERS}"]
